{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Win32",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceRoot}/out/build/debug/examples/basic/basic_example.exe",
      "args": [],
      "cwd": "${workspaceRoot}"
    },
    {
      "name": "Launch GTK",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceRoot}/out/build/debug-linux/examples/basic_gtk/basic_gtk",
      "args": [],
      "cwd": "${workspaceRoot}"
    },
    {
      "name": "Launch Python (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "C:/Program Files/Python312/python.exe",
      "args": [
        "${workspaceFolder}/examples/python/main.py"
      ],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "stopAtEntry": false,
      "externalConsole": false
    },
    {
      "name": "(Linux) Launch Python (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "/bin/python3",
      "args": [
        "${workspaceFolder}/examples/python/main.py"
      ],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "stopAtEntry": false,
      "externalConsole": false
    }
  ]
}